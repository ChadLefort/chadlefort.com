---
import { Picture } from 'astro:assets';
import { Icon } from 'astro-icon/components';
import me from '~/assets/me.png';
import { Terminal } from '~/components/Terminal/Terminal';
import { CTALink } from '~/components/CTALink';
---

<header class="relative px-4 pt-8 pb-0 sm:px-6 sm:pt-10 md:pt-20" data-no-print data-hero>
  <div class="max-w-section mx-auto flex w-full flex-col items-center gap-6 md:gap-14">
    <div class="flex flex-col items-center gap-6 text-center md:flex-row md:gap-12 md:text-left" data-testid="hero-intro">
      <figure class="ring-glass-border-strong relative m-0 h-36 w-36 overflow-hidden rounded-full ring-1 md:h-44 md:w-44">
        <Picture
          src={me}
          alt="Chad Lefort"
          width={176}
          height={176}
          densities={[1, 2, 3]}
          loading="eager"
          fetchpriority="high"
          formats={['avif', 'webp']}
          fallbackFormat="webp"
          quality={95}
          pictureAttributes={{ class: 'block h-full w-full' }}
          class="h-full w-full object-cover"
        />
        <div aria-hidden="true" class="bg-ink-300 pointer-events-none absolute inset-0 opacity-50 mix-blend-color">
        </div>
      </figure>
      <div class="max-w-xl">
        <h1 class="font-display ml-0 text-6xl tracking-[-0.08em] sm:-ml-[8px] md:text-8xl" data-hero-name>
          Chad Lefort
        </h1>
        <p class="mt-3 text-xl text-accent font-medium md:text-2xl">Senior Frontend Engineer</p>
      </div>
    </div>

    <Terminal client:idle />

    <CTALink href="/chad-lefort-resume.pdf" download size="lg" client:idle>
      <Icon
        name="lucide:download"
        class="h-5 w-5 transition-transform group-hover:-translate-y-0.5"
        aria-hidden="true"
      />
      Download Resume
    </CTALink>
  </div>
</header>
