---
import { getImage } from 'astro:assets';
import about1 from '~/assets/about/about-1.png';
import about2 from '~/assets/about/about-2.png';
import about3 from '~/assets/about/about-3.png';
import about4 from '~/assets/about/about-4.png';
import about5 from '~/assets/about/about-5.png';
import { AboutMeSwiper } from '~/components/AboutMeSwiper';
import Section from '~/components/Section.astro';

const sources = [about1, about2, about3, about4, about5];
const widths = [260, 400, 500];
const toSrcSet = async (src: (typeof sources)[number], format: 'avif' | 'webp') => {
  const variants = await Promise.all(
    widths.map(async (w) => {
      const img = await getImage({ src, width: w, format, quality: 88 });
      return `${img.src} ${w}w`;
    })
  );

  return variants.join(', ');
};

const processed = await Promise.all(
  sources.map(async (src, index) => {
    const [avif, webp, fallback] = await Promise.all([
      toSrcSet(src, 'avif'),
      toSrcSet(src, 'webp'),
      getImage({ src, width: 500, format: 'webp', quality: 88 })
    ]);

    return {
      avif,
      webp,
      src: fallback.src,
      alt: `Chad Lefort, candid ${index + 1} of ${sources.length}`
    };
  })
);
---

<Section id="about-me" title="About me" tone="alt" hideFromPrint>
  <div class="mx-auto grid max-w-5xl items-center gap-12 md:grid-cols-[minmax(0,300px)_1fr]">
    <AboutMeSwiper client:visible images={processed} />
    <div class="text-fg-muted space-y-5 text-base leading-relaxed md:text-lg">
      <p>
        I've been a technology enthusiast ever since a young age. Whether it's looking at source code or computer
        hardware, I've always enjoyed tinkering around to understand how things work. Shortly after I was given my first
        computer at 11 years old, I started the journey of creating web sites and fell in love with the web and
        programming.
      </p>
      <p>
        When I'm not programming, I enjoy taking daily walks with my wife Melanie and taking naps on the couch with my
        cat. I also enjoy skateboarding a couple of times a week (even though my knees don't), riding my bike on trails,
        playing guitar, and adventuring in video games.
      </p>
    </div>
  </div>
</Section>
