---
import AboutMe from '~/sections/home/AboutMe.astro';
import Contact from '~/sections/home/Contact.astro';
import Education from '~/sections/home/Education.astro';
import Header from '~/sections/home/Header.astro';
import JobExperience from '~/sections/home/JobExperience.astro';
import PrintHeader from '~/sections/home/PrintHeader.astro';
import Skills from '~/sections/home/Skills.astro';
import { site } from '~/data/site';
import Base from '~/layouts/Base.astro';

const profileLd = {
  '@context': 'https://schema.org',
  '@type': 'ProfilePage',
  dateCreated: '2013-12-01',
  dateModified: new Date().toISOString().slice(0, 10),
  mainEntity: { '@type': 'Person', '@id': `${site.siteUrl}#chad-lefort`, name: site.name }
};
---

<Base structuredData={profileLd} compactLogo>
  <PrintHeader />
  <Header />
  <JobExperience />
  <Skills />
  <Education />
  <AboutMe />
  <Contact />
</Base>
