---
import { type CollectionEntry, getCollection } from 'astro:content';
import Base from '~/layouts/Base.astro';
import Section from '~/components/Section.astro';
import ProjectCards from '~/components/projects/ProjectCards.astro';
import { site } from '~/data/site';

type Project = CollectionEntry<'projects'>;

const raw = await getCollection('projects');
const projects = raw.sort((a: Project, b: Project) => a.data.order - b.data.order);

const collectionLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'Projects',
  description: "Selected case studies from Chad Lefort's frontend engineering work.",
  url: `${site.siteUrl}/projects`,
  isPartOf: { '@type': 'WebSite', name: site.name, url: site.siteUrl },
  hasPart: projects.map((project: Project) => ({
    '@type': 'CreativeWork',
    name: project.data.title,
    description: project.data.summary,
    url: `${site.siteUrl}/projects/${project.id}`,
    ...(project.data.tech?.length ? { keywords: project.data.tech.join(', ') } : {}),
    ...(project.data.start ? { dateCreated: project.data.start } : {}),
    ...(project.data.end ? { dateModified: project.data.end } : {}),
    author: { '@type': 'Person', name: site.name, url: site.siteUrl }
  }))
};

const breadcrumbLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: site.siteUrl },
    { '@type': 'ListItem', position: 2, name: 'Projects', item: `${site.siteUrl}/projects` }
  ]
};
---

<Base
  title="Projects"
  description="Selected case studies from Chad Lefort's frontend engineering work."
  pathname="/projects"
  structuredData={[collectionLd, breadcrumbLd]}
>
  <section class="px-4 pt-20 pb-8 sm:px-6 md:pt-28">
    <div class="max-w-section mx-auto">
      <p class="text-accent font-mono text-xs tracking-[0.3em] uppercase">Some things I've shipped</p>
      <h1 class="font-display mt-3 text-4xl md:text-6xl">Projects</h1>
      <p class="text-fg-muted mt-4 max-w-2xl text-lg">
        A tour through shipped products, platform migrations, and frontend architecture bets. Each card opens a deeper
        write-up with screenshots, stack choices, and outcomes.
      </p>
    </div>
  </section>

  <Section id="all-projects" tone="base">
    <ProjectCards projects={projects} />
  </Section>
</Base>
