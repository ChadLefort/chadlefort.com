---
import { Image, getImage } from 'astro:assets';
import { type CollectionEntry, getCollection, render } from 'astro:content';
import { Icon } from 'astro-icon/components';
import Base from '~/layouts/Base.astro';
import { ProjectGallery } from '~/components/react/ProjectGallery';
import ProjectTabs from '~/components/projects/ProjectTabs.astro';
import { type NavLink } from '~/data/nav';
import { site } from '~/data/site';

type Props = { project: CollectionEntry<'projects'> };

export const getStaticPaths = async () => {
  const projects = await getCollection('projects');

  return projects.map((project: CollectionEntry<'projects'>) => ({
    params: { slug: project.id },
    props: { project }
  }));
};

const { project } = Astro.props as Props;
const { Content } = await render(project);

const navLinks: NavLink[] = [
  { href: '/', label: 'Home', icon: 'lucide:home' },
  { href: '/#job-experience', label: 'Experience', icon: 'lucide:briefcase' },
  { href: '/#contact', label: 'Contact', icon: 'lucide:mail' },
  { href: '/projects', label: 'Projects', icon: 'lucide:layout-dashboard' }
];

type GalleryItem = NonNullable<CollectionEntry<'projects'>['data']['gallery']>[number];

const gallery = await Promise.all(
  (project.data.gallery ?? []).map(async (item: GalleryItem) => {
    const optimized = await getImage({ src: item.src, width: 1600, format: 'webp', quality: 82 });
    const aspect =
      optimized.attributes.width && optimized.attributes.height
        ? Number(optimized.attributes.width) / Number(optimized.attributes.height)
        : 1;
    const orientation: 'portrait' | 'landscape' = aspect < 0.85 ? 'portrait' : 'landscape';

    return { src: optimized.src, alt: item.alt, orientation };
  })
);

const coverUrl = project.data.cover
  ? new URL((await getImage({ src: project.data.cover, width: 1200, format: 'webp' })).src, site.siteUrl).toString()
  : undefined;

const projectLd: Record<string, unknown> = {
  '@context': 'https://schema.org',
  '@type': 'CreativeWork',
  name: project.data.title,
  headline: project.data.title,
  description: project.data.summary,
  url: new URL(`/projects/${project.id}`, site.siteUrl).toString(),
  author: { '@type': 'Person', name: site.name, url: site.siteUrl },
  creator: { '@type': 'Person', name: site.name, url: site.siteUrl }
};

if (project.data.tech?.length) projectLd.keywords = project.data.tech.join(', ');
if (project.data.start) projectLd.dateCreated = project.data.start;
if (project.data.end) projectLd.dateModified = project.data.end;
if (coverUrl) projectLd.image = coverUrl;
if (project.data.externalUrl) projectLd.sameAs = project.data.externalUrl;

const breadcrumbLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: site.siteUrl },
    { '@type': 'ListItem', position: 2, name: 'Projects', item: `${site.siteUrl}/projects` },
    {
      '@type': 'ListItem',
      position: 3,
      name: project.data.title,
      item: `${site.siteUrl}/projects/${project.id}`
    }
  ]
};
---

<Base
  title={project.data.title}
  description={project.data.summary}
  image={coverUrl}
  pathname={`/projects/${project.id}`}
  navLinks={navLinks}
  showLogoOnDesktop
  structuredData={[projectLd, breadcrumbLd]}
>
  <article>
    <section class="relative px-4 pt-12 pb-16 sm:px-6 md:pt-20 md:pb-24">
      <div class="max-w-section mx-auto">
        <a
          href="/projects"
          class="inline-flex items-center gap-1.5 rounded-full border border-[var(--glass-border)] bg-[var(--glass-bg)] px-3 py-1.5 text-sm font-semibold text-[var(--text)] transition hover:bg-[var(--glass-bg-strong)] focus-visible:ring-2 focus-visible:ring-[var(--color-accent)] focus-visible:outline-none"
        >
          <Icon name="lucide:chevron-left" class="h-4 w-4" aria-hidden="true" />
          Back to projects
        </a>

        <div class="mt-10 grid gap-10 md:grid-cols-[minmax(0,1fr)_minmax(0,1fr)] md:items-center md:gap-14">
          <div>
            <p class="font-mono text-xs tracking-[0.3em] text-[var(--color-accent)] uppercase">
              {project.data.subtitle}
            </p>
            <h1 class="font-display mt-3 text-5xl tracking-tight md:text-6xl">{project.data.title}</h1>
            <p class="mt-6 text-lg leading-relaxed text-[var(--text-muted)] md:text-xl">{project.data.summary}</p>

            <ul class="mt-8 flex flex-wrap gap-2">
              {
                project.data.tech.map((tag: string) => (
                  <li class="rounded-full border border-[var(--glass-border)] bg-[var(--glass-bg)] px-3 py-1 text-xs font-semibold tracking-wide text-[var(--text)]">
                    {tag}
                  </li>
                ))
              }
            </ul>

            <div class="mt-10 flex flex-wrap gap-3">
              {
                project.data.externalUrl && (
                  <a
                    href={project.data.externalUrl}
                    target="_blank"
                    rel="noopener"
                    class="inline-flex scale-100 items-center gap-2 rounded-xl bg-[var(--color-accent-strong)] px-6 py-3 font-semibold text-white transition-all duration-200 hover:scale-[1.02] hover:bg-[var(--color-accent)] focus-visible:ring-2 focus-visible:ring-[var(--color-accent)] focus-visible:ring-offset-2 focus-visible:ring-offset-[var(--surface)] focus-visible:outline-none active:scale-[0.98] motion-reduce:hover:scale-100"
                  >
                    <Icon name="lucide:external-link" class="h-4 w-4" aria-hidden="true" />
                    Visit live site
                  </a>
                )
              }
              {
                project.data.repoUrl && (
                  <a
                    href={project.data.repoUrl}
                    target="_blank"
                    rel="noopener"
                    class="inline-flex scale-100 items-center gap-2 rounded-xl border border-[var(--glass-border-strong)] bg-[var(--glass-bg)] px-6 py-3 font-semibold text-[var(--text)] transition-all duration-200 hover:scale-[1.02] hover:border-[var(--color-accent)] focus-visible:ring-2 focus-visible:ring-[var(--color-accent)] focus-visible:ring-offset-2 focus-visible:ring-offset-[var(--surface)] focus-visible:outline-none active:scale-[0.98] motion-reduce:hover:scale-100"
                  >
                    <Icon name="lucide:github" class="h-4 w-4" aria-hidden="true" />
                    Repository
                  </a>
                )
              }
            </div>
          </div>

          {
            project.data.cover && (
              <div class="overflow-hidden rounded-2xl border border-[var(--glass-border)] bg-[var(--surface-raised)]">
                <Image
                  src={project.data.cover}
                  alt={project.data.title}
                  width={1400}
                  format="webp"
                  quality={82}
                  loading="eager"
                  class="h-full w-full object-cover"
                />
              </div>
            )
          }
        </div>
      </div>
    </section>

    <section class="px-4 pb-24 sm:px-6 md:pb-32">
      <div class="max-w-section mx-auto">
        <ProjectTabs hasGallery={gallery.length > 0}>
          <div slot="description" class="card p-8 md:p-16">
            <div class="project-prose">
              <Content />
            </div>
          </div>

          {
            gallery.length > 0 && (
              <div slot="gallery">
                <ProjectGallery client:load images={gallery} title={project.data.title} />
              </div>
            )
          }
        </ProjectTabs>
      </div>
    </section>
  </article>
</Base>
