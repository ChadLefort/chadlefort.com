---
import { Picture, getImage } from 'astro:assets';
import { type CollectionEntry, getCollection, render } from 'astro:content';
import { Icon } from 'astro-icon/components';
import Base from '~/layouts/Base.astro';
import { ProjectTabsIsland } from '~/components/react/ProjectTabsIsland';
import { site } from '~/data/site';

type Props = { project: CollectionEntry<'projects'> };

export const getStaticPaths = async () => {
  const projects = await getCollection('projects');

  return projects.map((project: CollectionEntry<'projects'>) => ({
    params: { slug: project.id },
    props: { project }
  }));
};

const { project } = Astro.props as Props;
const { Content } = await render(project);

type GalleryItem = NonNullable<CollectionEntry<'projects'>['data']['gallery']>[number];

const landscapeWidths = [640, 960, 1200];
const portraitWidths = [260, 400, 520];
const landscapeSizes = '(min-width: 768px) 600px, 100vw';
const portraitSizes = '260px';

const toThumbSrcSet = async (src: GalleryItem['src'], widths: number[], format: 'avif' | 'webp') => {
  const variants = await Promise.all(
    widths.map(async (w) => {
      const img = await getImage({ src, width: w, format, quality: 82 });
      return `${img.src} ${w}w`;
    })
  );

  return variants.join(', ');
};

const gallery = await Promise.all(
  (project.data.gallery ?? []).map(async (item: GalleryItem) => {
    const probe = await getImage({ src: item.src, width: 1600, format: 'webp', quality: 82 });
    const aspect =
      probe.attributes.width && probe.attributes.height
        ? Number(probe.attributes.width) / Number(probe.attributes.height)
        : 1;
    const orientation: 'portrait' | 'landscape' = aspect < 0.85 ? 'portrait' : 'landscape';
    const widths = orientation === 'portrait' ? portraitWidths : landscapeWidths;
    const sizes = orientation === 'portrait' ? portraitSizes : landscapeSizes;

    const [thumbAvif, thumbWebp, thumbFallback, fullAvif] = await Promise.all([
      toThumbSrcSet(item.src, widths, 'avif'),
      toThumbSrcSet(item.src, widths, 'webp'),
      getImage({ src: item.src, width: widths[widths.length - 1], format: 'webp', quality: 82 }),
      getImage({ src: item.src, width: 1600, format: 'avif', quality: 72 })
    ]);

    return {
      src: probe.src,
      fullAvif: fullAvif.src,
      thumbSrc: thumbFallback.src,
      thumbAvif,
      thumbWebp,
      thumbSizes: sizes,
      alt: item.alt,
      orientation,
      width: Number(probe.attributes.width ?? 1),
      height: Number(probe.attributes.height ?? 1)
    };
  })
);

const coverUrl = project.data.cover
  ? new URL((await getImage({ src: project.data.cover, width: 1200, format: 'webp' })).src, site.siteUrl).toString()
  : undefined;

const projectLd: Record<string, unknown> = {
  '@context': 'https://schema.org',
  '@type': 'CreativeWork',
  name: project.data.title,
  headline: project.data.title,
  description: project.data.summary,
  url: new URL(`/projects/${project.id}`, site.siteUrl).toString(),
  author: { '@type': 'Person', name: site.name, url: site.siteUrl },
  creator: { '@type': 'Person', name: site.name, url: site.siteUrl }
};

if (project.data.tech?.length) projectLd.keywords = project.data.tech.join(', ');
if (project.data.start) projectLd.dateCreated = project.data.start;
if (project.data.end) projectLd.dateModified = project.data.end;
if (coverUrl) projectLd.image = coverUrl;
if (project.data.externalUrl) projectLd.sameAs = project.data.externalUrl;

const breadcrumbLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: site.siteUrl },
    { '@type': 'ListItem', position: 2, name: 'Projects', item: `${site.siteUrl}/projects` },
    {
      '@type': 'ListItem',
      position: 3,
      name: project.data.title,
      item: `${site.siteUrl}/projects/${project.id}`
    }
  ]
};

const backLinkClass =
  'border-glass-border bg-glass text-fg hover:bg-glass-strong focus-visible:ring-accent inline-flex items-center gap-1.5 rounded-full border px-3 py-1.5 text-sm font-semibold transition focus-visible:ring-2 focus-visible:outline-none';

const primaryCtaClass =
  'bg-accent-strong hover:bg-accent focus-visible:ring-accent focus-visible:ring-offset-surface inline-flex items-center gap-2 rounded-xl px-6 py-3 font-semibold text-white transition-all duration-200 hover:scale-[1.02] focus-visible:ring-2 focus-visible:ring-offset-2 focus-visible:outline-none active:scale-[0.98] motion-reduce:hover:scale-100';

const secondaryCtaClass =
  'border-glass-border-strong bg-glass text-fg hover:border-accent focus-visible:ring-accent focus-visible:ring-offset-surface inline-flex items-center gap-2 rounded-xl border px-6 py-3 font-semibold transition-all duration-200 hover:scale-[1.02] focus-visible:ring-2 focus-visible:ring-offset-2 focus-visible:outline-none active:scale-[0.98] motion-reduce:hover:scale-100';
---

<Base
  title={project.data.title}
  description={project.data.summary}
  image={coverUrl}
  pathname={`/projects/${project.id}`}
  structuredData={[projectLd, breadcrumbLd]}
>
  <article>
    <section class="relative px-4 pt-12 pb-16 sm:px-6 md:pt-20 md:pb-24">
      <div class="max-w-section mx-auto">
        <a href="/projects" class={backLinkClass}>
          <Icon name="lucide:chevron-left" class="h-4 w-4" aria-hidden="true" />
          Back to projects
        </a>

        <div class="mt-10 grid gap-10 md:grid-cols-[minmax(0,1fr)_minmax(0,1fr)] md:items-center md:gap-14">
          <div>
            <p class="text-accent font-mono text-xs tracking-[0.3em] uppercase">{project.data.subtitle}</p>
            <h1 class="font-display mt-3 text-5xl md:text-6xl">{project.data.title}</h1>
            <p class="text-fg-muted mt-6 text-lg leading-relaxed md:text-xl">{project.data.summary}</p>

            <ul class="mt-8 flex flex-wrap gap-2">
              {
                project.data.tech.map((tag: string) => (
                  <li class="border-glass-border bg-glass text-fg rounded-full border px-3 py-1 text-xs font-semibold tracking-wide">
                    {tag}
                  </li>
                ))
              }
            </ul>

            <div class="mt-10 flex flex-wrap gap-3">
              {
                project.data.externalUrl && (
                  <a href={project.data.externalUrl} target="_blank" rel="noopener" class={primaryCtaClass}>
                    <Icon name="lucide:external-link" class="h-4 w-4" aria-hidden="true" />
                    Visit live site
                  </a>
                )
              }
              {
                project.data.repoUrl && (
                  <a href={project.data.repoUrl} target="_blank" rel="noopener" class={secondaryCtaClass}>
                    <Icon name="lucide:github" class="h-4 w-4" aria-hidden="true" />
                    Repository
                  </a>
                )
              }
            </div>
          </div>

          {
            project.data.cover && (
              <div class="border-glass-border bg-surface-raised overflow-hidden rounded-2xl border">
                <Picture
                  src={project.data.cover}
                  alt={project.data.title}
                  widths={[640, 960, 1280, 1600]}
                  sizes="(min-width: 768px) 640px, 100vw"
                  formats={['avif', 'webp']}
                  fallbackFormat="webp"
                  quality={82}
                  loading="eager"
                  fetchpriority="high"
                  pictureAttributes={{ class: 'block h-full w-full' }}
                  class="h-full w-full object-cover"
                />
              </div>
            )
          }
        </div>
      </div>
    </section>

    <section class="px-4 pb-24 sm:px-6 md:pb-32">
      <div class="max-w-section mx-auto">
        <ProjectTabsIsland
          client:load
          hasGallery={gallery.length > 0}
          galleryImages={gallery}
          title={project.data.title}
        >
          <Fragment slot="description">
            <Content />
          </Fragment>
        </ProjectTabsIsland>
      </div>
    </section>
  </article>
</Base>
