---
import { getImage, Picture } from 'astro:assets';
import { type CollectionEntry, getCollection, render } from 'astro:content';
import { Icon } from 'astro-icon/components';
import { ProjectTabsIsland } from '~/components/ProjectTabsIsland';
import { cta, pillLink } from '~/components/cta';
import { site } from '~/data/site';
import Base from '~/layouts/Base.astro';

type Props = { project: CollectionEntry<'projects'> };

export const getStaticPaths = async () => {
  const projects = await getCollection('projects');

  return projects.map((project: CollectionEntry<'projects'>) => ({
    params: { slug: project.id },
    props: { project }
  }));
};

const { project } = Astro.props as Props;
const { Content } = await render(project);

type GalleryItem = NonNullable<CollectionEntry<'projects'>['data']['gallery']>[number];

const landscapeWidths = [640, 960, 1200];
const portraitWidths = [260, 400, 520];
const landscapeSizes = '(min-width: 768px) 600px, 100vw';
const portraitSizes = '260px';
const thumbAspectByDevice = {
  desktop: 16 / 9,
  mobile: 9 / 16
} as const;

const getClampedWidths = (widths: number[], maxWidth: number) => {
  const clamped = [...new Set(widths.map((width) => Math.min(width, maxWidth)).filter((width) => width > 0))];

  return clamped.length > 0 ? clamped : [maxWidth];
};

const toThumbSrcSet = async (
  src: GalleryItem['src'],
  widths: number[],
  aspectRatio: number,
  format: 'avif' | 'webp'
) => {
  const variants = await Promise.all(
    widths.map(async (w) => {
      const img = await getImage({
        src,
        width: w,
        height: Math.round(w / aspectRatio),
        fit: 'cover',
        position: 'top',
        format,
        quality: 82
      });
      return `${img.src} ${w}w`;
    })
  );

  return variants.join(', ');
};

const gallery = await Promise.all(
  (project.data.gallery ?? []).map(async (item: GalleryItem) => {
    const width = item.src.width;
    const height = item.src.height;
    const aspect = width && height ? width / height : 1;
    const orientation: 'portrait' | 'landscape' = aspect < 0.85 ? 'portrait' : 'landscape';
    const device: 'desktop' | 'mobile' = item.device ?? (orientation === 'portrait' ? 'mobile' : 'desktop');
    const requestedWidths = device === 'mobile' ? portraitWidths : landscapeWidths;
    const thumbWidths = getClampedWidths(requestedWidths, width);
    const sizes = device === 'mobile' ? portraitSizes : landscapeSizes;
    const thumbAspect = thumbAspectByDevice[device];
    const fullWidth = Math.min(width, 1600);

    const [thumbAvif, thumbWebp, thumbFallback, fullAvif, fullWebp] = await Promise.all([
      toThumbSrcSet(item.src, thumbWidths, thumbAspect, 'avif'),
      toThumbSrcSet(item.src, thumbWidths, thumbAspect, 'webp'),
      getImage({
        src: item.src,
        width: thumbWidths[thumbWidths.length - 1],
        height: Math.round(thumbWidths[thumbWidths.length - 1] / thumbAspect),
        fit: 'cover',
        position: 'top',
        format: 'webp',
        quality: 82
      }),
      getImage({ src: item.src, width: fullWidth, format: 'avif', quality: 72 }),
      getImage({ src: item.src, width: fullWidth, format: 'webp', quality: 82 })
    ]);

    return {
      src: fullWebp.src,
      fullAvif: fullAvif.src,
      thumbSrc: thumbFallback.src,
      thumbAvif,
      thumbWebp,
      thumbSizes: sizes,
      alt: item.alt,
      device,
      initialZoom: item.initialZoom,
      orientation,
      width,
      height
    };
  })
);

const coverUrl = project.data.cover
  ? new URL((await getImage({ src: project.data.cover, width: 1200, format: 'webp' })).src, site.siteUrl).toString()
  : undefined;

const projectLd: Record<string, unknown> = {
  '@context': 'https://schema.org',
  '@type': 'CreativeWork',
  name: project.data.title,
  headline: project.data.title,
  description: project.data.summary,
  url: new URL(`/projects/${project.id}`, site.siteUrl).toString(),
  author: { '@type': 'Person', name: site.name, url: site.siteUrl },
  creator: { '@type': 'Person', name: site.name, url: site.siteUrl }
};

if (project.data.tech?.length) projectLd.keywords = project.data.tech.join(', ');
if (project.data.start) projectLd.dateCreated = project.data.start;
if (project.data.end) projectLd.dateModified = project.data.end;
if (coverUrl) projectLd.image = coverUrl;
if (project.data.externalUrl) projectLd.sameAs = project.data.externalUrl;

const breadcrumbLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: site.siteUrl },
    { '@type': 'ListItem', position: 2, name: 'Projects', item: `${site.siteUrl}/projects` },
    {
      '@type': 'ListItem',
      position: 3,
      name: project.data.title,
      item: `${site.siteUrl}/projects/${project.id}`
    }
  ]
};
---

<Base
  title={project.data.title}
  description={project.data.summary}
  image={coverUrl}
  pathname={`/projects/${project.id}`}
  structuredData={[projectLd, breadcrumbLd]}
>
  <article>
    <section class="relative px-4 pt-12 pb-16 sm:px-6 md:pt-20 md:pb-24">
      <div class="max-w-section mx-auto">
        <a href="/projects" class={pillLink()}>
          <Icon name="lucide:chevron-left" class="h-4 w-4" aria-hidden="true" />
          Back to projects
        </a>

        <div class="mt-8 grid gap-8 md:grid-cols-[minmax(0,1fr)_minmax(0,1fr)] md:items-center md:gap-12">
          <div>
            <p class="text-accent font-mono text-xs tracking-[0.3em] uppercase">{project.data.subtitle}</p>
            <h1 class="font-display mt-3 text-5xl md:text-6xl">{project.data.title}</h1>
            <p class="text-fg-muted mt-5 text-lg leading-relaxed md:text-xl">{project.data.summary}</p>

            <ul class="mt-6 flex flex-wrap gap-2">
              {
                project.data.tech.map((tag: string) => (
                  <li class="border-glass-border bg-glass text-fg rounded-full border px-3 py-1 text-xs font-semibold tracking-wide">
                    {tag}
                  </li>
                ))
              }
            </ul>

            <div class="mt-8 flex flex-wrap gap-3">
              {
                project.data.externalUrl && (
                  <a href={project.data.externalUrl} target="_blank" rel="noopener" class={cta({ intent: 'primary' })}>
                    <Icon name="lucide:external-link" class="h-4 w-4" aria-hidden="true" />
                    Visit live site
                  </a>
                )
              }
              {
                project.data.repoUrl && (
                  <a href={project.data.repoUrl} target="_blank" rel="noopener" class={cta({ intent: 'secondary' })}>
                    <Icon name="lucide:github" class="h-4 w-4" aria-hidden="true" />
                    Repository
                  </a>
                )
              }
            </div>
          </div>

          {
            project.data.cover && (
              <Picture
                src={project.data.cover}
                alt={project.data.title}
                widths={[640, 960, 1280, 1600]}
                sizes="(min-width: 768px) 640px, 100vw"
                formats={['avif', 'webp']}
                fallbackFormat="webp"
                quality={82}
                loading="eager"
                fetchpriority="high"
                pictureAttributes={{ class: 'block aspect-video w-full overflow-hidden rounded-2xl' }}
                class="h-full w-full object-cover object-top"
              />
            )
          }
        </div>
      </div>
    </section>

    <section class="px-4 pb-24 sm:px-6 md:pb-32">
      <div class="max-w-section mx-auto">
        <ProjectTabsIsland
          client:load
          hasGallery={gallery.length > 0}
          galleryImages={gallery}
          title={project.data.title}
        >
          <Fragment slot="description">
            <Content />
          </Fragment>
        </ProjectTabsIsland>
      </div>
    </section>
  </article>
</Base>
