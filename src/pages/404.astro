---
import { buttonStyles } from '~/components/Button';
import Base from '~/layouts/Base.astro';
---

<Base title="Page not found" description="The page you're looking for doesn't exist.">
  <section class="flex min-h-[60vh] flex-col items-center justify-center gap-4 px-4 text-center">
    <p class="text-fg-muted font-mono text-sm">404</p>
    <h1 class="font-display text-4xl md:text-5xl">Page not found</h1>
    <p class="text-fg-muted max-w-md">
      The link might be broken or the page may have moved. Head back home to find what you're looking for.
    </p>
    <a href="/" class={buttonStyles({ variant: 'solid', color: 'brand', size: 'lg' })}>Back home</a>
  </section>
</Base>
