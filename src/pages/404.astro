---
import Base from '~/layouts/Base.astro';
---

<Base title="Page not found" description="The page you're looking for doesn't exist.">
  <section class="flex min-h-[60vh] flex-col items-center justify-center gap-4 px-4 text-center">
    <p class="font-mono text-sm text-[var(--text-muted)]">404</p>
    <h1 class="font-display text-4xl md:text-5xl">Page not found</h1>
    <p class="max-w-md text-[var(--text-muted)]">
      The link might be broken or the page may have moved. Head back home to find what you're looking for.
    </p>
    <a
      href="/"
      class="inline-flex items-center gap-2 rounded-lg bg-[var(--color-ink-900)] px-5 py-2.5 font-semibold text-white transition hover:bg-[var(--color-ink-800)] focus-visible:ring-2 focus-visible:ring-[var(--color-accent)] focus-visible:outline-none"
    >
      Back home
    </a>
  </section>
</Base>
