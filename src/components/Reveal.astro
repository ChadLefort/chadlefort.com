---
export type Props = {
  class?: string;
  as?: 'div' | 'li' | 'section' | 'article';
  delay?: number;
};

const { class: className, as: Tag = 'div', delay = 0 } = Astro.props;

const classes = ['fade-up', className].filter(Boolean).join(' ');
---

<Tag class={classes} style={delay ? `transition-delay: ${delay}ms;` : undefined} data-reveal>
  <slot />
</Tag>
