---
import { Icon } from 'astro-icon/components';
import { tv } from 'tailwind-variants';
import Logo from '~/components/Logo.astro';
import { MobileDrawer } from '~/components/MobileDrawer';
import { ThemeToggle } from '~/components/ThemeToggle';
import { homeNav, type NavLink } from '~/data/nav';

type Props = {
  links?: NavLink[];
  showLogoOnDesktop?: boolean;
  compactLogo?: boolean;
};

const { links = homeNav, showLogoOnDesktop = true, compactLogo = false } = Astro.props;

const navLink = tv({
  base: [
    'inline-flex items-center gap-2 rounded-lg px-3 py-2 text-sm font-semibold tracking-wide transition',
    'text-nav-fg/85 hover:text-nav-fg hover:bg-black/10 dark:hover:bg-white/5',
    'focus-visible:outline-2 focus-visible:-outline-offset-2 focus-visible:outline-accent'
  ]
});
---

<a href="#main" class="skip-link">Skip to main content</a>

<header
  data-no-print
  data-nav
  data-nav-compact={compactLogo ? 'true' : 'false'}
  class="glass-nav text-nav-fg sticky top-0 z-30"
>
  <div
    class="max-w-section nav:grid nav:grid-cols-[1fr_auto_1fr] mx-auto hidden h-16 w-full items-center gap-4 px-4 sm:px-6"
  >
    <div class="flex items-center justify-start">
      {
        showLogoOnDesktop && (
          <a
            href="/"
            data-nav-logo
            aria-label="Chad Lefort home"
            class="font-display text-base font-bold tracking-[-0.06em] [word-spacing:-0.2em] hover:opacity-90"
          >
            <Logo as="span" size="sm" />
          </a>
        )
      }
    </div>

    <nav aria-label="Primary" class="flex items-center justify-center gap-1">
      {
        links.map((link) => (
          <a href={link.href} class={navLink()}>
            <Icon name={link.icon} class="h-4 w-4 opacity-70" aria-hidden="true" />
            {link.label}
          </a>
        ))
      }
    </nav>

    <div class="flex items-center justify-end">
      <ThemeToggle client:load />
    </div>
  </div>

  <div class="max-w-section nav:hidden mx-auto flex h-16 w-full items-center justify-between gap-4 px-4 sm:px-6">
    <a
      href="/"
      data-nav-logo
      aria-label="Chad Lefort home"
      class="font-display text-base font-bold tracking-[-0.06em] [word-spacing:-0.2em] hover:opacity-90"
    >
      <Logo as="span" size="sm" />
    </a>
    <div class="flex items-center gap-1">
      <ThemeToggle client:load />
      <MobileDrawer client:idle links={links} />
    </div>
  </div>
</header>

<script>
  import { navigate } from 'astro:transitions/client';
  import { typeText } from '~/utils/typeText';

  const onLogoClick = (e: MouseEvent) => {
    const link = (e.target as HTMLElement | null)?.closest<HTMLAnchorElement>('[data-nav-logo]');

    if (!link || e.metaKey || e.ctrlKey || e.shiftKey || e.altKey || e.button !== 0) return;

    e.preventDefault();
    void navigate(link.getAttribute('href') ?? '/');
  };

  document.addEventListener('click', onLogoClick);

  const TEXT = 'Chad Lefort';

  let io: IntersectionObserver | undefined;

  const setStaticText = (el: HTMLElement) => {
    el.textContent = TEXT;
    el.dataset.typed = 'true';
  };

  const typeInto = (el: HTMLElement) => {
    if (el.dataset.typed === 'true') return;

    el.dataset.typed = 'true';
    typeText(el, TEXT);
  };

  const setup = () => {
    io?.disconnect();

    const nav = document.querySelector<HTMLElement>('[data-nav]');

    if (!nav) return;

    const isHomePage = window.location.pathname === '/';
    const trigger = document.querySelector<HTMLElement>('[data-hero-name]');
    const texts = nav.querySelectorAll<HTMLElement>('[data-logo-text]');

    if (!texts.length) return;

    if (!isHomePage || !trigger) {
      nav.dataset.navCompact = 'false';
      texts.forEach(setStaticText);
      return;
    }

    texts.forEach((el) => {
      el.textContent = '';
      delete el.dataset.typed;
    });

    const NAV_HEIGHT = 64;

    io = new IntersectionObserver(
      (entries) => {
        const entry = entries[0];
        const rootTop = entry.rootBounds?.top ?? NAV_HEIGHT;
        const past = !entry.isIntersecting && entry.boundingClientRect.bottom <= rootTop;

        nav.dataset.navCompact = past ? 'false' : 'true';

        if (!past) return;

        texts.forEach(typeInto);
      },
      { rootMargin: `-${NAV_HEIGHT}px 0px 0px 0px` }
    );

    io.observe(trigger);
  };

  setup();
  document.addEventListener('astro:page-load', setup);
</script>
