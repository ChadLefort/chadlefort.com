---
import { Image } from 'astro:assets';
import { Icon } from 'astro-icon/components';
import Reveal from '~/components/Reveal.astro';
import type { CollectionEntry } from 'astro:content';

type ProjectEntry = CollectionEntry<'projects'>;

type Props = {
  projects: ProjectEntry[];
};

const { projects } = Astro.props;

const spanClass = {
  sm: 'md:col-span-3 md:row-span-1',
  md: 'md:col-span-3 md:row-span-1',
  lg: 'md:col-span-4 md:row-span-1',
  xl: 'md:col-span-6 md:row-span-1'
} as const;
---

<ul class="grid auto-rows-[minmax(260px,auto)] grid-cols-1 gap-6 md:grid-cols-6">
  {
    projects.map((project: ProjectEntry, index: number) => {
      const span = project.data.span as keyof typeof spanClass;
      const href = `/projects/${project.id}`;
      return (
        <Reveal as="li" delay={index * 80} class={spanClass[span]}>
          <a
            href={href}
            class="group card card-hover focus-visible:ring-accent relative block h-full overflow-hidden focus-visible:ring-2 focus-visible:outline-none"
          >
            <div class="absolute inset-0">
              <Image
                src={project.data.cover}
                alt={project.data.coverAlt}
                width={1200}
                format="webp"
                quality={78}
                loading={index < 2 ? 'eager' : 'lazy'}
                class="h-full w-full object-cover opacity-50 transition duration-500 group-hover:scale-[1.04] group-hover:opacity-70"
              />
              <div class={`absolute inset-0 bg-gradient-to-br ${project.data.accent}`} />
              <div class="from-ink-950/95 via-ink-950/65 absolute inset-0 bg-gradient-to-t to-transparent" />
            </div>

            <div class="relative flex h-full flex-col justify-end gap-3 p-7 text-white">
              <p class="font-mono text-xs tracking-[0.25em] text-white/70 uppercase">{project.data.subtitle}</p>
              <h3 class="font-display text-2xl md:text-3xl">{project.data.title}</h3>
              <p class="max-w-prose text-sm leading-relaxed text-white/85">{project.data.summary}</p>
              <ul class="mt-3 flex flex-wrap gap-1.5">
                {project.data.tech.slice(0, 6).map((tag: string) => (
                  <li class="rounded-full border border-white/15 bg-white/10 px-2.5 py-0.5 text-xs font-semibold tracking-wide text-white/90 backdrop-blur">
                    {tag}
                  </li>
                ))}
                {project.data.tech.length > 6 && (
                  <li class="rounded-full border border-white/10 bg-white/5 px-2.5 py-0.5 text-xs font-semibold tracking-wide text-white/70">
                    +{project.data.tech.length - 6}
                  </li>
                )}
              </ul>
            </div>

            <span
              aria-hidden="true"
              class="absolute top-5 right-5 inline-flex h-10 w-10 items-center justify-center rounded-full border border-white/15 bg-white/10 text-white backdrop-blur transition group-hover:border-white/30 group-hover:bg-white/20"
            >
              <Icon
                name="lucide:arrow-up-right"
                class="h-4 w-4 transition-transform duration-300 group-hover:rotate-12 motion-reduce:group-hover:rotate-0"
                aria-hidden="true"
              />
            </span>
          </a>
        </Reveal>
      );
    })
  }
</ul>
