---
import { Icon } from 'astro-icon/components';

type Props = {
  hasGallery: boolean;
};

const { hasGallery } = Astro.props;
---

<div class="project-tabs" data-default={hasGallery ? 'description' : 'description'}>
  <div
    role="tablist"
    aria-label="Project sections"
    class="mb-10 flex items-center gap-2 border-b border-[var(--glass-border)]"
  >
    <button
      type="button"
      role="tab"
      aria-selected="true"
      aria-controls="panel-description"
      data-tab="description"
      class="project-tab inline-flex items-center gap-2 border-b-2 border-transparent px-5 py-3 text-sm font-semibold tracking-wide text-[var(--text-muted)] transition hover:text-[var(--text)] focus-visible:ring-2 focus-visible:ring-[var(--color-accent)] focus-visible:outline-none aria-selected:border-[var(--color-accent)] aria-selected:text-[var(--text)]"
    >
      <Icon name="lucide:file-text" class="h-4 w-4" aria-hidden="true" />
      Description
    </button>
    {
      hasGallery && (
        <button
          type="button"
          role="tab"
          aria-selected="false"
          aria-controls="panel-gallery"
          data-tab="gallery"
          class="project-tab inline-flex items-center gap-2 border-b-2 border-transparent px-5 py-3 text-sm font-semibold tracking-wide text-[var(--text-muted)] transition hover:text-[var(--text)] focus-visible:ring-2 focus-visible:ring-[var(--color-accent)] focus-visible:outline-none aria-selected:border-[var(--color-accent)] aria-selected:text-[var(--text)]"
        >
          <Icon name="lucide:images" class="h-4 w-4" aria-hidden="true" />
          Images
        </button>
      )
    }
  </div>

  <div id="panel-description" role="tabpanel" data-panel="description">
    <slot name="description" />
  </div>

  {
    hasGallery && (
      <div id="panel-gallery" role="tabpanel" data-panel="gallery" hidden>
        <slot name="gallery" />
      </div>
    )
  }
</div>

<script>
  const init = () => {
    document.querySelectorAll<HTMLElement>('.project-tabs').forEach((root) => {
      const tabs = Array.from(root.querySelectorAll<HTMLButtonElement>('[role="tab"]'));
      const panels = root.querySelectorAll<HTMLElement>('[role="tabpanel"]');

      const syncTabindex = () => {
        tabs.forEach((tab) => {
          tab.tabIndex = tab.getAttribute('aria-selected') === 'true' ? 0 : -1;
        });
      };

      const select = (key: string, focus = false) => {
        tabs.forEach((tab) => tab.setAttribute('aria-selected', String(tab.dataset.tab === key)));
        panels.forEach((panel) => {
          if (panel.dataset.panel === key) {
            panel.removeAttribute('hidden');
          } else {
            panel.setAttribute('hidden', '');
          }
        });

        syncTabindex();

        if (focus) {
          tabs.find((t) => t.dataset.tab === key)?.focus();
        }
      };

      const moveFocus = (fromIndex: number, delta: number) => {
        const next = (fromIndex + delta + tabs.length) % tabs.length;
        const key = tabs[next].dataset.tab;

        if (key) select(key, true);
      };

      tabs.forEach((tab, index) => {
        tab.addEventListener('click', () => tab.dataset.tab && select(tab.dataset.tab));
        tab.addEventListener('keydown', (event) => {
          switch (event.key) {
            case 'ArrowRight':
            case 'ArrowDown':
              event.preventDefault();
              moveFocus(index, 1);
              break;
            case 'ArrowLeft':
            case 'ArrowUp':
              event.preventDefault();
              moveFocus(index, -1);
              break;
            case 'Home': {
              event.preventDefault();
              const key = tabs[0].dataset.tab;

              if (key) select(key, true);
              break;
            }
            case 'End': {
              event.preventDefault();
              const key = tabs[tabs.length - 1].dataset.tab;

              if (key) select(key, true);
              break;
            }
          }
        });
      });

      syncTabindex();
    });
  };

  document.addEventListener('astro:page-load', init);
  init();
</script>
