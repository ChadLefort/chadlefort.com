---
import Section from '~/components/Section.astro';
import Nicholls from '~/assets/logos/nicholls.svg';
---

<Section id="education" eyebrow="Where I learned" title="Education" tone="base">
  <article class="mx-auto w-full max-w-5xl">
    <header class="grid grid-cols-[1fr_auto] items-start gap-8">
      <div>
        <h3 class="font-display text-2xl tracking-tight md:text-3xl">Nicholls State University</h3>
        <p class="mt-1 text-sm font-semibold text-[var(--color-accent)] md:text-base">Bachelor of Science (B.S.)</p>
        <p class="mt-1 font-mono text-xs text-[var(--text-muted)] md:text-sm">August 2009 &ndash; December 2013</p>
      </div>
      <Nicholls aria-label="Nicholls State Colonels" class="h-14 w-auto md:h-20 print:h-10" />
    </header>

    <hr class="my-6 border-t border-[var(--glass-border)]" />

    <ul class="space-y-2 text-sm text-[var(--text-muted)] md:text-base">
      <li class="flex gap-3">
        <span aria-hidden="true" class="mt-2 inline-block h-1.5 w-1.5 shrink-0 rounded-full bg-[var(--color-accent)]"
        ></span>
        <span>Majored in Computer Information Systems</span>
      </li>
      <li class="flex gap-3">
        <span aria-hidden="true" class="mt-2 inline-block h-1.5 w-1.5 shrink-0 rounded-full bg-[var(--color-accent)]"
        ></span>
        <span>GPA: 3.6</span>
      </li>
    </ul>

    <h4 class="font-display mt-10 text-lg md:text-xl">Awards</h4>
    <ul class="mt-3 space-y-2 text-sm text-[var(--text-muted)] md:text-base">
      <li class="flex gap-3">
        <span aria-hidden="true" class="mt-2 inline-block h-1.5 w-1.5 shrink-0 rounded-full bg-[var(--color-accent)]"
        ></span>
        <span
          >Consistently awarded the President's List since the Fall 2010 semester (scholastic GPA of 3.5 or higher
          required).</span
        >
      </li>
    </ul>

    <h4 class="font-display mt-10 text-lg md:text-xl">Organizations</h4>
    <ul class="mt-3 space-y-2 text-sm text-[var(--text-muted)] md:text-base">
      <li class="flex gap-3">
        <span aria-hidden="true" class="mt-2 inline-block h-1.5 w-1.5 shrink-0 rounded-full bg-[var(--color-accent)]"
        ></span>
        <span
          >Member of Beta Gamma Sigma, the highest recognition for a business student at an AACSB-accredited program.</span
        >
      </li>
      <li class="flex gap-3">
        <span aria-hidden="true" class="mt-2 inline-block h-1.5 w-1.5 shrink-0 rounded-full bg-[var(--color-accent)]"
        ></span>
        <span
          >Member of Upsilon Pi Epsilon, the first international honor society in the computing and information
          disciplines.</span
        >
      </li>
    </ul>
  </article>
</Section>
