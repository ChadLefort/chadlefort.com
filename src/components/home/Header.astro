---
import { Picture } from 'astro:assets';
import { Icon } from 'astro-icon/components';
import { Terminal } from '~/components/react/Terminal';
import me from '~/assets/me.png';
---

<section class="relative px-4 pt-8 pb-6 sm:px-6 sm:pt-10 sm:pb-8 md:pt-20 md:pb-10" data-no-print data-hero>
  <div class="max-w-section mx-auto flex w-full flex-col items-center gap-8 sm:gap-10 md:gap-12">
    <div class="flex flex-col items-center gap-6 text-center md:flex-row md:items-center md:gap-12 md:text-left">
      <div class="ring-glass-border-strong relative h-36 w-36 overflow-hidden rounded-full ring-1 md:h-44 md:w-44">
        <Picture
          src={me}
          alt="Chad Lefort"
          width={176}
          height={176}
          densities={[1, 2, 3]}
          loading="eager"
          fetchpriority="high"
          formats={['avif', 'webp']}
          fallbackFormat="webp"
          quality={95}
          pictureAttributes={{ class: 'block h-full w-full' }}
          class="h-full w-full object-cover"
        />
        <div aria-hidden="true" class="bg-ink-300 pointer-events-none absolute inset-0 opacity-50 mix-blend-color">
        </div>
      </div>
      <div class="max-w-xl">
        <p class="text-accent font-mono text-xs tracking-[0.3em] uppercase">$ whoami</p>
        <h1 class="font-display mt-3 text-6xl md:text-8xl" data-hero-name>Chad Lefort</h1>
        <p class="text-fg-muted mt-3 text-xl font-medium md:text-2xl">Senior Frontend Engineer</p>
      </div>
    </div>

    <Terminal client:idle />

    <a
      href="/chad-lefort-resume.pdf"
      download
      class="group bg-accent-strong hover:bg-accent focus-visible:ring-accent focus-visible:ring-offset-surface inline-flex scale-100 items-center gap-3 rounded-xl px-8 py-4 text-lg font-bold text-white transition-all duration-200 hover:scale-[1.02] focus-visible:ring-2 focus-visible:ring-offset-2 focus-visible:outline-none active:scale-[0.98] motion-reduce:hover:scale-100"
    >
      <Icon
        name="lucide:download"
        class="h-5 w-5 transition-transform group-hover:-translate-y-0.5"
        aria-hidden="true"
      />
      Download Resume
    </a>
  </div>
</section>
