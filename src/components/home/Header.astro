---
import { Image } from 'astro:assets';
import { Icon } from 'astro-icon/components';
import { Terminal } from '~/components/react/Terminal';
import { yearsOfExperience } from '~/data/site';
import me from '~/assets/me.png';

const years = yearsOfExperience();
---

<section class="relative px-4 pt-12 pb-10 sm:px-6 md:pt-20" data-no-print>
  <div class="max-w-section mx-auto flex w-full flex-col items-center gap-12">
    <div class="flex flex-col items-center gap-8 text-center md:flex-row md:items-center md:gap-12 md:text-left">
      <div
        class="relative h-44 w-44 overflow-hidden rounded-full ring-1 ring-[var(--glass-border-strong)] md:h-56 md:w-56"
      >
        <Image
          src={me}
          alt="Chad Lefort portrait"
          width={220}
          height={220}
          loading="eager"
          fetchpriority="high"
          format="webp"
          quality={88}
          class="h-full w-full object-cover"
        />
        <div
          aria-hidden="true"
          class="pointer-events-none absolute inset-0 mix-blend-color"
          style="background: var(--color-9); opacity: 0.5;"
        >
        </div>
      </div>
      <div class="max-w-xl">
        <p class="font-mono text-xs tracking-[0.3em] text-[var(--color-accent)] uppercase">$ whoami</p>
        <h1 class="font-display mt-3 text-5xl tracking-tight md:text-7xl">Chad Lefort</h1>
        <p class="mt-3 text-xl font-medium text-[var(--text-muted)] md:text-2xl">Senior Frontend Engineer</p>
        <p class="mt-5 text-base leading-relaxed text-[var(--text-muted)] md:text-lg">
          Frontend engineer from Louisiana with {years}+ years shipping maintainable, accessible, and fast web apps for
          teams of every size.
        </p>
      </div>
    </div>

    <Terminal client:load />

    <a
      href="/chad-lefort-resume.pdf"
      download
      class="group inline-flex scale-100 items-center gap-3 rounded-xl bg-[var(--color-accent-strong)] px-8 py-4 text-lg font-bold text-white transition-all duration-200 hover:scale-[1.02] hover:bg-[var(--color-accent)] focus-visible:ring-2 focus-visible:ring-[var(--color-accent)] focus-visible:ring-offset-2 focus-visible:ring-offset-[var(--surface)] focus-visible:outline-none active:scale-[0.98] motion-reduce:hover:scale-100"
    >
      <Icon
        name="lucide:download"
        class="h-5 w-5 transition-transform group-hover:-translate-y-0.5"
        aria-hidden="true"
      />
      Download Resume
    </a>
  </div>
</section>
