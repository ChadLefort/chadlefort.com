---
import { Icon } from 'astro-icon/components';
import Section from '~/components/Section.astro';
import { site } from '~/data/site';

const links = [
  { label: 'Email', href: `mailto:${site.email}`, icon: 'lucide:mail' },
  { label: 'GitHub', href: site.social.github, icon: 'lucide:github' },
  { label: 'LinkedIn', href: site.social.linkedin, icon: 'lucide:linkedin' },
  { label: 'Twitter', href: site.social.twitter, icon: 'lucide:twitter' },
  { label: 'Instagram', href: site.social.instagram, icon: 'lucide:instagram' },
  { label: 'YouTube', href: site.social.youtube, icon: 'lucide:youtube' }
];
---

<Section id="contact" eyebrow="Get in touch" title="Contact" tone="base" hideFromPrint>
  <div class="mx-auto max-w-3xl text-center">
    <p class="text-fg-muted text-lg">Have questions or a job opportunity? Let's get in touch.</p>
    <ul class="mt-10 flex flex-wrap items-center justify-center gap-3">
      {
        links.map((link) => (
          <li>
            <a
              href={link.href}
              rel={link.href.startsWith('http') ? 'noopener' : undefined}
              target={link.href.startsWith('http') ? '_blank' : undefined}
              aria-label={link.label}
              class="group card card-hover text-fg focus-visible:ring-accent inline-flex h-14 w-14 items-center justify-center focus-visible:ring-2 focus-visible:outline-none"
            >
              <Icon
                name={link.icon}
                class="h-6 w-6 transition-transform duration-300 group-hover:scale-110 motion-reduce:group-hover:scale-100"
                aria-hidden="true"
              />
            </a>
          </li>
        ))
      }
    </ul>
    <div class="mt-8 flex justify-center">
      <button
        type="button"
        data-copy-email
        data-email={site.email}
        class="group border-glass-border bg-glass text-fg hover:border-accent focus-visible:ring-accent inline-flex cursor-pointer items-center gap-3 rounded-full border px-4 py-2 font-mono text-sm transition focus-visible:ring-2 focus-visible:outline-none"
        aria-label={`Copy email ${site.email} to clipboard`}
      >
        <Icon name="lucide:mail" class="text-accent h-4 w-4" aria-hidden="true" />
        <span data-copy-email-label>{site.email}</span>
        <Icon
          name="lucide:copy"
          class="text-fg-muted group-hover:text-accent h-4 w-4 transition"
          aria-hidden="true"
          data-copy-email-icon
        />
      </button>
    </div>
  </div>
</Section>

<script>
  const init = () => {
    document.querySelectorAll<HTMLButtonElement>('[data-copy-email]').forEach((btn) => {
      if (btn.dataset.copyEmailBound) return;
      btn.dataset.copyEmailBound = 'true';

      const label = btn.querySelector<HTMLElement>('[data-copy-email-label]');
      const original = label?.textContent ?? '';

      btn.addEventListener('click', async () => {
        const email = btn.dataset.email ?? '';

        try {
          await navigator.clipboard.writeText(email);
        } catch {
          return;
        }

        if (label) label.textContent = 'Copied!';

        window.setTimeout(() => {
          if (label) label.textContent = original;
        }, 1800);
      });
    });
  };

  document.addEventListener('astro:page-load', init);
  init();
</script>
