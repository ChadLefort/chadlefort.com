---
import { Icon } from 'astro-icon/components';
import { tv } from 'tailwind-variants';
import Section from '~/components/Section.astro';
import { site } from '~/data/site';

const links = [
  { label: 'Email', href: `mailto:${site.email}`, icon: 'lucide:mail' },
  { label: 'GitHub', href: site.social.github, icon: 'simple-icons:github' },
  { label: 'LinkedIn', href: site.social.linkedin, icon: 'simple-icons:linkedin' },
  { label: 'Twitter', href: site.social.twitter, icon: 'simple-icons:twitter' },
  { label: 'Bluesky', href: site.social.bluesky, icon: 'simple-icons:bluesky' },
  { label: 'Instagram', href: site.social.instagram, icon: 'simple-icons:instagram' },
  { label: 'YouTube', href: site.social.youtube, icon: 'simple-icons:youtube' }
].map((link) => ({
  ...link,
  external: link.href.startsWith('http')
}));

const socialButton = tv({
  base: [
    'group card card-hover text-fg',
    'inline-flex h-14 w-14 items-center justify-center',
    'focus-visible:outline-2 focus-visible:-outline-offset-2 focus-visible:outline-accent'
  ]
});

const copyEmailButton = tv({
  base: [
    'group inline-flex cursor-pointer items-center gap-3',
    'border-glass-border bg-glass text-fg rounded-full border px-4 py-2 font-mono text-sm',
    'backdrop-blur-[24px] backdrop-saturate-[160%]',
    'hover:border-accent transition',
    'focus-visible:outline-2 focus-visible:-outline-offset-2 focus-visible:outline-accent'
  ]
});
---

<Section id="contact" title="Contact" tone="alt" hideFromPrint>
  <div class="mx-auto max-w-3xl text-center">
    <p class="text-fg-muted text-lg">Have questions or a job opportunity? Let's get in touch.</p>
    <address class="mt-10 flex flex-col items-center not-italic">
      <ul class="flex flex-wrap items-center justify-center gap-3" aria-label="Social and contact links">
        {
          links.map((link) => (
            <li>
              <a
                href={link.href}
                rel={link.external ? 'noopener' : undefined}
                target={link.external ? '_blank' : undefined}
                aria-label={link.external ? `${link.label} (opens in a new tab)` : link.label}
                class={socialButton()}
              >
                <Icon
                  name={link.icon}
                  class="h-6 w-6 transition-transform duration-300 group-hover:scale-110 motion-reduce:group-hover:scale-100"
                  aria-hidden="true"
                />
              </a>
            </li>
          ))
        }
      </ul>
      <div class="mt-8 flex justify-center">
        <button
          type="button"
          data-copy-email
          data-email={site.email}
          class={copyEmailButton()}
          aria-label={`Copy email ${site.email} to clipboard`}
        >
          <Icon name="lucide:mail" class="text-accent h-4 w-4" aria-hidden="true" />
          <span data-copy-email-label>{site.email}</span>
          <Icon
            name="lucide:copy"
            class="text-fg-muted group-hover:text-accent h-4 w-4 transition"
            aria-hidden="true"
            data-copy-email-icon
          />
        </button>
      </div>
      <p class="sr-only" data-copy-email-status aria-live="polite"></p>
    </address>
  </div>
</Section>

<script>
  const init = () => {
    document.querySelectorAll<HTMLButtonElement>('[data-copy-email]').forEach((btn) => {
      if (btn.dataset.copyEmailBound) return;

      btn.dataset.copyEmailBound = 'true';

      const label = btn.querySelector<HTMLElement>('[data-copy-email-label]');
      const status = btn.parentElement?.parentElement?.querySelector<HTMLElement>('[data-copy-email-status]');
      const original = label?.textContent ?? '';

      btn.addEventListener('click', async () => {
        const email = btn.dataset.email ?? '';

        try {
          await navigator.clipboard.writeText(email);
        } catch {
          return;
        }

        if (label) label.textContent = 'Copied!';
        if (status) status.textContent = 'Email copied to clipboard.';

        window.setTimeout(() => {
          if (label) label.textContent = original;
          if (status) status.textContent = '';
        }, 1800);
      });
    });
  };

  document.addEventListener('astro:page-load', init);
  init();
</script>
