---
import { tv } from 'tailwind-variants';

type Props = {
  id: string;
  tone?: 'base' | 'alt' | 'hero' | 'plain';
  class?: string;
  title?: string;
  eyebrow?: string;
  as?: 'section' | 'div';
  hideFromPrint?: boolean;
  printOnly?: boolean;
  titleAlign?: 'center' | 'left';
  width?: 'narrow' | 'wide' | 'full';
  tile?: boolean;
};

const {
  id,
  tone = 'base',
  class: className,
  title,
  eyebrow,
  as: Tag = 'section',
  hideFromPrint = false,
  printOnly = false,
  titleAlign = 'center',
  width = 'wide',
  tile = true
} = Astro.props as Props;

const section = tv({
  base: 'relative scroll-mt-24 px-4 py-5 sm:px-6 sm:py-8 md:py-16 print:p-0'
});

const tile$ = tv({
  base: 'relative mx-auto w-full px-5 py-10 sm:px-10 sm:py-14 md:py-28 lg:px-16 print:p-0',
  variants: {
    width: {
      narrow: 'max-w-4xl',
      wide: 'max-w-section',
      full: 'max-w-shell'
    },
    tone: {
      base: 'tile bg-tile border-glass-border rounded-3xl border',
      alt: 'tile bg-tile-alt border-glass-border rounded-3xl border',
      hero: 'tile bg-tile border-glass-border rounded-3xl border',
      plain: ''
    },
    tileOff: {
      true: '!border-0 !bg-transparent'
    }
  }
});

const header = tv({
  base: 'mb-8 flex flex-col gap-4 sm:mb-12 md:mb-20',
  variants: {
    align: {
      center: 'items-center text-center',
      left: 'items-start text-left'
    }
  }
});

const tileOff = !tile || tone === 'plain';
---

<Tag
  id={id}
  class={section({ class: className })}
  data-no-print={hideFromPrint ? true : undefined}
  data-print-only={printOnly ? true : undefined}
>
  <div class={tile$({ width, tone, tileOff })}>
    {
      (title || eyebrow) && (
        <header class={header({ align: titleAlign })}>
          {eyebrow && <p class="text-accent font-mono text-xs tracking-[0.3em] uppercase">{eyebrow}</p>}
          {title && <h2 class="font-display text-4xl md:text-6xl">{title}</h2>}
        </header>
      )
    }
    <slot />
  </div>
</Tag>
