---
import { tv } from 'tailwind-variants';

type Props = {
  as?: 'h1' | 'h2' | 'span' | 'div';
  class?: string;
  size?: 'sm' | 'md' | 'lg';
};

const { as: Tag = 'span', class: className, size = 'md' } = Astro.props as Props;

const styles = tv({
  base: 'font-display tracking-wide',
  variants: {
    size: {
      sm: 'text-xl',
      md: 'text-2xl',
      lg: 'text-5xl md:text-6xl'
    }
  }
});
---

<Tag class={styles({ size, class: className })}>Chad Lefort</Tag>
