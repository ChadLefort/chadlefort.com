---
import { Icon } from 'astro-icon/components';
import { tv } from 'tailwind-variants';

type Props = {
  as?: 'h1' | 'h2' | 'span' | 'div';
  class?: string;
  size?: 'sm' | 'md' | 'lg';
  showIcon?: boolean;
  showText?: boolean;
};

const { as: Tag = 'span', class: className, size = 'md', showIcon = true, showText = true } = Astro.props as Props;

const styles = tv({
  base: 'font-display inline-flex items-center gap-2 tracking-[-0.06em]',
  variants: {
    size: {
      sm: 'text-xl',
      md: 'text-2xl',
      lg: 'text-5xl md:text-6xl'
    }
  }
});

const iconClass = size === 'lg' ? 'h-10 w-10 md:h-12 md:w-12' : size === 'md' ? 'h-7 w-7' : 'h-6 w-6';
---

<Tag class={styles({ size, class: className })}>
  {showIcon && <Icon name="lucide:terminal" class={`text-accent shrink-0 ${iconClass}`} aria-hidden="true" />}
  {showText && <span data-logo-text>Chad Lefort</span>}
</Tag>
