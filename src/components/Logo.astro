---
import { Picture } from 'astro:assets';
import { tv } from 'tailwind-variants';
import icon from '~/assets/icon.png';

type Props = {
  as?: 'h1' | 'h2' | 'span' | 'div';
  class?: string;
  size?: 'sm' | 'md' | 'lg';
  showIcon?: boolean;
};

const { as: Tag = 'span', class: className, size = 'md', showIcon = true } = Astro.props as Props;

const styles = tv({
  base: 'font-display inline-flex items-center gap-2 tracking-wide',
  variants: {
    size: {
      sm: 'text-xl',
      md: 'text-2xl',
      lg: 'text-5xl md:text-6xl'
    }
  }
});

const iconSize = size === 'lg' ? 56 : size === 'md' ? 32 : 24;
---

<Tag class={styles({ size, class: className })}>
  {
    showIcon && (
      <Picture
        src={icon}
        alt=""
        width={iconSize}
        height={iconSize}
        densities={[1, 2, 3]}
        quality={95}
        formats={['avif', 'webp']}
        fallbackFormat="webp"
        loading="eager"
        pictureAttributes={{ class: 'inline-flex shrink-0' }}
        class="shrink-0 rounded-md"
      />
    )
  }
  <span>Chad Lefort</span>
</Tag>
