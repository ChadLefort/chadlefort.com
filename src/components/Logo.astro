---
type Props = {
  as?: 'h1' | 'h2' | 'span' | 'div';
  class?: string;
  size?: 'sm' | 'md' | 'lg';
};

const { as: Tag = 'span', class: className = '', size = 'md' } = Astro.props as Props;

const sizeClass = size === 'lg' ? 'text-5xl md:text-6xl' : size === 'sm' ? 'text-xl' : 'text-2xl';
---

<Tag class={`font-display tracking-wide ${sizeClass} ${className}`}>Chad Lefort</Tag>
