{
  "name": "chadlefort.com",
  "private": true,
  "description": "Personal website",
  "version": "2.0.0",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/ChadLefort/chadlefort.com.git"
  },
  "scripts": {
    "dev": "astro dev --host",
    "start": "astro dev --host",
    "build": "astro build",
    "assets:brand": "node scripts/generate-brand-assets.mjs",
    "assets:favicon": "node scripts/generate-favicon.mjs",
    "preview": "astro preview",
    "astro": "astro",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "prettier --write \"**/*.{astro,ts,tsx,js,jsx,mjs,cjs,json,md,mdx,css}\"",
    "format:check": "prettier --check \"**/*.{astro,ts,tsx,js,jsx,mjs,cjs,json,md,mdx,css}\"",
    "typecheck": "astro check && tsgo --noEmit",
    "typecheck:tsc": "astro check && tsc --noEmit",
    "test": "vitest --run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "audit": "fallow audit",
    "dead-code": "fallow dead-code",
    "dupes": "fallow dupes",
    "health": "fallow health",
    "fallow:fix": "fallow fix --yes",
    "fallow:fix:preview": "fallow fix --dry-run",
    "prepare": "husky"
  },
  "dependencies": {
    "@astrojs/mdx": "^4.3.0",
    "@astrojs/react": "^4.3.0",
    "@astrojs/sitemap": "^3.4.0",
    "@iconify-json/lucide": "^1.2.102",
    "@iconify-json/mdi": "^1.2.3",
    "@iconify-json/simple-icons": "^1.2.58",
    "@iconify/react": "^6.0.2",
    "@tailwindcss/vite": "^4.1.16",
    "astro": "^5.15.0",
    "astro-icon": "^1.1.5",
    "lucide-react": "^1.9.0",
    "react": "^19.2.0",
    "react-aria-components": "^1.17.0",
    "react-dom": "^19.2.0",
    "sharp": "^0.34.1",
    "swiper": "^12.0.1",
    "tailwind-merge": "^3.5.0",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "^4.1.16"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.4",
    "@iconify-icons/lucide": "^1.2.135",
    "@iconify-icons/simple-icons": "^1.2.74",
    "@iconify-json/devicon": "^1.2.62",
    "@playwright/test": "^1.59.1",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.6.4",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^22.15.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@typescript/native-preview": "^7.0.0-dev.20260424.1",
    "@vite-pwa/astro": "^1.2.0",
    "@vitejs/plugin-react": "^5.0.0",
    "@vitest/coverage-v8": "^3.2.3",
    "@vitest/ui": "^3.2.3",
    "axe-core": "^4.11.0",
    "fallow": "^2.48.4",
    "husky": "^9.1.7",
    "jsdom": "^27.0.0",
    "lint-staged": "^16.2.0",
    "oxlint": "^1.23.0",
    "oxlint-tsgolint": "^0.21.1",
    "prettier": "^3.6.2",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-tailwindcss": "^0.6.14",
    "sharp-ico": "^0.1.5",
    "typescript": "^5.9.3",
    "vitest": "^3.2.3",
    "vitest-axe": "^0.1.0"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,astro,mjs,cjs}": "oxlint --fix",
    "*.{ts,tsx,js,jsx,astro,mjs,cjs,json,md,mdx,css}": "prettier --write"
  }
}
