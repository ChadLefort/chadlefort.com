{
  "name": "chadlefort.com",
  "private": true,
  "description": "Personal website",
  "version": "2.0.0",
  "license": "MIT",
  "type": "module",
  "packageManager": "bun@1.3.10",
  "repository": {
    "type": "git",
    "url": "https://github.com/ChadLefort/chadlefort.com.git"
  },
  "scripts": {
    "dev": "astro dev --host",
    "start": "astro dev --host",
    "prebuild": "bun scripts/generate-build-info.ts",
    "build": "astro build",
    "assets:brand": "bun scripts/generate-brand-assets.ts",
    "assets:favicon": "bun scripts/generate-favicon.ts",
    "hooks:install": "bun scripts/install-git-hooks.ts",
    "hooks:list": "git hook list pre-commit",
    "hooks:uninstall": "bun scripts/uninstall-git-hooks.ts",
    "preview": "astro preview",
    "astro": "astro",
    "lint": "biome check . --files-ignore-unknown=true",
    "lint:fix": "biome check . --write --files-ignore-unknown=true --config-path biome.write.jsonc",
    "format": "biome format . --write --files-ignore-unknown=true --config-path biome.write.jsonc",
    "format:check": "biome format . --files-ignore-unknown=true --config-path biome.write.jsonc",
    "typecheck": "astro check && tsgo --noEmit && bun run typecheck:scripts",
    "typecheck:tsc": "astro check && tsc --noEmit && bun run typecheck:scripts",
    "typecheck:scripts": "tsc -p tsconfig.scripts.json --noEmit",
    "test": "vitest --run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:update": "playwright test --update-snapshots",
    "test:e2e:ui": "playwright test --ui",
    "audit": "fallow audit",
    "dead-code": "fallow dead-code",
    "dupes": "fallow dupes",
    "health": "fallow health",
    "fallow:fix": "fallow fix --yes",
    "fallow:fix:preview": "fallow fix --dry-run",
    "prepare": "bun run hooks:install"
  },
  "dependencies": {
    "@astrojs/mdx": "^4.3.14",
    "@astrojs/react": "^4.4.2",
    "@astrojs/sitemap": "^3.7.2",
    "@iconify-json/lucide": "^1.2.106",
    "@iconify-json/mdi": "^1.2.3",
    "@iconify-json/simple-icons": "^1.2.81",
    "@iconify/react": "^6.0.2",
    "@nanostores/react": "^1.1.0",
    "@tailwindcss/vite": "^4.3.0",
    "astro": "^5.18.1",
    "astro-icon": "^1.1.5",
    "dedent": "^1.7.2",
    "lucide-react": "^1.14.0",
    "nanostores": "^1.3.0",
    "react": "^19.2.6",
    "react-aria-components": "^1.17.0",
    "react-dom": "^19.2.6",
    "sharp": "^0.34.5",
    "swiper": "^12.1.4",
    "tailwind-merge": "^3.6.0",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "^4.3.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@biomejs/biome": "^2.4.15",
    "@iconify-icons/lucide": "^1.2.135",
    "@iconify-icons/simple-icons": "^1.2.74",
    "@iconify-json/devicon": "^1.2.62",
    "@playwright/test": "^1.59.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/bun": "^1.3.13",
    "@types/node": "^22.19.18",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript/native-preview": "^7.0.0-dev.20260510.1",
    "@vitejs/plugin-react": "^5.2.0",
    "@vitest/coverage-v8": "^3.2.4",
    "@vitest/ui": "^3.2.4",
    "axe-core": "^4.11.4",
    "fallow": "^2.69.0",
    "happy-dom": "^20.9.0",
    "lint-staged": "^16.4.0",
    "sharp-ico": "^0.1.5",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4",
    "vitest-axe": "^0.1.0"
  }
}
