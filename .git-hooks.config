[hook "01-lint-staged"]
	event = pre-commit
	command = bunx lint-staged

[hook "02-typecheck"]
	event = pre-commit
	command = bun run typecheck

[hook "03-test"]
	event = pre-commit
	command = bun run test

[hook "04-assets-brand"]
	event = pre-commit
	command = bun scripts/precommit-assets-brand.ts
